# Raw downloaded data — never commit (large, regenerable)
ml-pipeline/data/raw/

# SQLite WAL files — transient, not part of the committed snapshot
*.db-shm
*.db-wal

# Generated report — written at runtime, not needed in git
ml-pipeline/data/backtest_results.json

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
.pytest_cache/
.ruff_cache/

# Node
node_modules/
frontend/dist/

# Editor swap files
*.swo
*.swp

# Claude Code local settings
.claude/
